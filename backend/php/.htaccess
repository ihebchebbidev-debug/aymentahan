# Do not rewrite API PHP files to the React index.html
<IfModule mod_rewrite.c>
  RewriteEngine Off
</IfModule>

# ---------- CORS (accept any origin) ----------------------------------
# Apache answers OPTIONS preflights itself without invoking PHP, so we
# must emit the Access-Control-* headers at the web-server level.
<IfModule mod_headers.c>
  # Echo the request Origin back so caches don't collapse across origins.
  SetEnvIf Origin "^(.*)$" ORIGIN_SUB=$1
  Header always set Access-Control-Allow-Origin "%{ORIGIN_SUB}e" env=ORIGIN_SUB
  Header always set Vary "Origin"
  Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
  # Reflect the requested headers, with a sane default when none are sent.
  SetEnvIf Access-Control-Request-Headers "^(.*)$" ACRH=$1
  Header always set Access-Control-Allow-Headers "%{ACRH}e" env=ACRH
  Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-Auth-Token, X-Request-ID, X-Client-Version, Cache-Control, Pragma" env=!ACRH
  Header always set Access-Control-Max-Age "86400"
</IfModule>

# Short-circuit CORS preflights with a 204 that carries the headers above.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} OPTIONS
  RewriteRule ^(.*)$ $1 [R=204,L]
</IfModule>
